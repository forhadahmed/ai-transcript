            min_file_size=256,
            recursive_glob=True,
            parse_fn=parse_transcript,
            auto_title_fn=auto_title,
            tool_summary_fn=tool_summary,
            tool_detail_fn=tool_detail,
            engine_label="Codex",
        )
    )
