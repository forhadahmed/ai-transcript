def apply_share_preset(args: argparse.Namespace) -> None:
    if args.share_safe or args.share_public:
        args.redact_home = True
        args.redact_env = True
        args.redact_email = True
        args.redact_ip = True
        args.redact_api_keys = True
        args.redact_paths = True
        args.no_cost = True

    if args.share_public:
        args.no_thinking = True
        args.no_timestamps = True
        args.no_tool_results = True


def serialize_forwarded_flags(args: argparse.Namespace) -> list[str]:
    extra_flags: list[str] = []
    for name in BOOL_FORWARD_FLAGS:
        if getattr(args, name, False):
            extra_flags.append(f"--{name.replace('_', '-')}")
    if args.font_size != 15:
        extra_flags.extend(["--font-size", str(args.font_size)])
    if args.code_font != "JetBrains Mono":
        extra_flags.extend(["--code-font", args.code_font])
    if args.title:
        extra_flags.extend(["--title", args.title])
    for pattern in args.redact_pattern:
        extra_flags.extend(["--redact-pattern", pattern])
    return extra_flags


def ts_fmt(ts_str: str) -> str:
    try:
        dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        return dt.strftime("%Y-%m-%d %H:%M:%S")
    except (TypeError, ValueError):
        return ts_str or ""


def ts_short(ts_str: str) -> str:
    try:
        dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        return dt.strftime("%H:%M:%S")
    except (TypeError, ValueError):
        return ""


def tok_str(value: int) -> str:
    if value >= 1_000_000:
        return f"{value / 1_000_000:.1f}M"
    if value >= 1000:
        return f"{value / 1000:.1f}k"
    return str(value)


def tok_color(value: int) -> str:
    if value >= 10000:
        return "#c62828"
    if value >= 5000:
        return "#e65100"
    if value >= 2000:
        return "#f9a825"
    return "#888"


def strip_system_tags(text: str) -> str:
    return SYSTEM_TAG_RE.sub("", text).strip()


def is_boilerplate_result(text: str, args: argparse.Namespace) -> bool:
    if args.show_boilerplate:
        return False
    return bool(BOILERPLATE_RE.match(text.strip()))


def safe_markdown_source(text: str, args: argparse.Namespace) -> str:
    if args.allow_unsafe_html:
        return text
    return html.escape(text, quote=False)


def extract_fenced_blocks(text: str) -> tuple[str, dict[str, str]]:
    placeholders: dict[str, str] = {}
    counter = 0

    def replacer(match: re.Match[str]) -> str:
        nonlocal counter
        counter += 1
        key = f"\x00FENCED{counter}\x00"
        indent = match.group(1) or ""
        lang = match.group(2) or ""
        body = match.group(3)
        if indent:
            body_lines = body.split("\n")
            body = "\n".join(
                line[len(indent):] if line.startswith(indent) else line
                for line in body_lines
            )
        lang_attr = f' class="language-{html.escape(lang)}"' if lang else ""
        placeholders[key] = f"<pre><code{lang_attr}>{html.escape(body)}</code></pre>"
        return f"\n{key}\n"

    cleaned = re.sub(
        r"^([ \t]*)`{3,}(\w*)\s*\n(.*?)^\1`{3,}\s*$",
        replacer,
        text,
        flags=re.MULTILINE | re.DOTALL,
    )
    return cleaned, placeholders


def render_markdown(text: str, args: argparse.Namespace) -> str:
    if not NEEDS_MD_RE.search(text):
        return f"<p>{html.escape(text)}</p>"

    source = safe_markdown_source(text, args)
    if MARKDOWN_BACKEND == "cmark":
        return cmarkgfm.github_flavored_markdown_to_html(source)

    source, placeholders = extract_fenced_blocks(source)
    if MARKDOWN_BACKEND == "markdown":
        md_engine = markdown.Markdown(extensions=["fenced_code", "tables", "nl2br", "sane_lists"])
        result = md_engine.convert(source)
    else:
        paragraphs = []
        for block in re.split(r"\n{2,}", source):
            block = block.strip()
            if not block:
                continue
            paragraphs.append(f"<p>{block.replace(chr(10), '<br>')}</p>")
        result = "\n".join(paragraphs) if paragraphs else "<p></p>"
    for key, replacement in placeholders.items():
        result = result.replace(f"<p>{key}</p>", replacement).replace(key, replacement)
    if "```" in result:
        parts = re.split(r"(<pre[^>]*>.*?</pre>|<code[^>]*>.*?</code>)", result, flags=re.DOTALL)
        for index, part in enumerate(parts):
            if not part.startswith("<pre") and not part.startswith("<code"):
                parts[index] = re.sub(r"`{3,}\w*", "", part)
        result = "".join(parts)
    return result


def mcp_name(raw: str) -> str:
    match = re.search(r"__(\w+)$", raw)
    return f"MCP:{match.group(1)}" if match else raw


def parse_tool_input(raw: Any) -> Any:
    if isinstance(raw, str):
        stripped = raw.strip()
        if not stripped:
            return {}
        if stripped.startswith("{") or stripped.startswith("["):
            try:
                return json_loads(stripped)
            except Exception:
                return raw
        return raw
    return raw


def codex_reasoning_text(payload: dict[str, Any]) -> str:
    content = payload.get("content")
    if isinstance(content, str) and content.strip():
        return content.strip()
    summary = payload.get("summary")
    if not isinstance(summary, list):
        return ""
    parts: list[str] = []
    for item in summary:
        if isinstance(item, str) and item.strip():
            parts.append(item.strip())
        elif isinstance(item, dict):
            text = item.get("text", "")
            if text:
                parts.append(str(text).strip())
    return "\n".join(part for part in parts if part)


def patch_summary(patch_text: str) -> str:
    match = PATCH_HEADER_RE.search(patch_text or "")
    if match:
        action, path = match.groups()
        return f"{action} {os.path.basename(path)}"
    first_line = (patch_text or "").strip().splitlines()
    if not first_line:
        return "apply_patch"
    return first_line[0][:140]


def parse_tool_output_text(raw: Any) -> tuple[str, bool]:
    if raw is None:
        return "", False
    if not isinstance(raw, str):
        return json.dumps(raw, indent=2, default=str), False

    stripped = raw.strip()
    if not stripped:
        return "", False

    is_error = False
    if stripped.startswith("{") or stripped.startswith("["):
        try:
            parsed = json_loads(stripped)
        except Exception:
            parsed = None
        if isinstance(parsed, dict):
            metadata = parsed.get("metadata", {})
            if isinstance(metadata, dict) and metadata.get("exit_code", 0):
                is_error = True
            text = parsed.get("output")
            if isinstance(text, str):
                return text, is_error
            return json.dumps(parsed, indent=2, default=str), is_error

    exit_match = EXIT_CODE_RE.search(raw)
    if exit_match and exit_match.group(1) != "0":
        is_error = True
    return raw, is_error


def tool_summary(block: dict[str, Any]) -> tuple[str, str]:
    name = block.get("name", "?")
    payload = block.get("input", {})
    if isinstance(payload, str):
        payload = {"text": payload}
    if name == "exec_command":
        label = payload.get("cmd", "")[:140]
        return f"$ {label}", "bash"
    if name == "apply_patch":
        return patch_summary(str(block.get("raw_input", payload.get("text", "")))), "edit"
    if name == "update_plan":
        plan = payload.get("plan", [])
        return f"update_plan ({len(plan)} step{'s' if len(plan) != 1 else ''})", "task"
    if name in ("spawn_agent", "send_input", "wait", "resume_agent", "close_agent"):
        return f"{name} {str(payload)[:90]}", "agent"
    if name == "web_search":
        return "web_search", "search"
    return name, "other"


def render_diff(old: str, new: str) -> str:
    old_lines = (old or "").splitlines(keepends=True)
    new_lines = (new or "").splitlines(keepends=True)
    import difflib

    diff = list(difflib.unified_diff(old_lines, new_lines, lineterm=""))
    if not diff and new and not old:
        content = "".join(
            f'<span class="diff-add">+{html.escape(line)}</span>'
            for line in new.split("\n")
        )
        return f'<pre class="diff-block">{content}</pre>'
    if not diff:
        return ""

    rows = []
    for line in diff:
        if line.startswith("---") or line.startswith("+++"):
            continue
        raw = html.escape(line.rstrip("\n"))
        if line.startswith("+"):
            rows.append(f'<span class="diff-add">{raw}</span>')
        elif line.startswith("-"):
            rows.append(f'<span class="diff-del">{raw}</span>')
        elif line.startswith("@@"):
            rows.append(f'<span class="diff-hunk">{raw}</span>')
        else:
            rows.append(f'<span class="diff-ctx">{raw}</span>')

    content = "".join(rows)
    if len(content) > 5000:
        cut = content.rfind("</span>", 0, 5000)
        if cut > 0:
            content = content[: cut + 7] + "\n...(truncated)"
        else:
            content = content[:5000] + "</span>\n...(truncated)"
    return f'<pre class="diff-block">{content}</pre>'


def tool_detail(block: dict[str, Any], args: argparse.Namespace) -> str:
    name = block.get("name", "?")
    payload = block.get("input", {})
    parts: list[str] = []
    if isinstance(payload, str):
        payload = {"text": payload}
    if name == "exec_command":
        for key in ("cmd", "workdir", "yield_time_ms"):
            value = payload.get(key)
            if value in (None, "", []):
                continue
            if key == "cmd":
                parts.append(f"<pre>{html.escape(str(value))}</pre>")
            else:
                parts.append(f'<div class="dim">{html.escape(key)}={html.escape(str(value))}</div>')
    elif name == "apply_patch":
        patch_text = str(block.get("raw_input", payload.get("text", "")))
        limit = len(patch_text) if args.full_output else 5000
        shown = patch_text[:limit]
        if len(patch_text) > limit:
            shown += f"\n...({len(patch_text)} chars)"
        parts.append(f"<pre>{html.escape(shown)}</pre>")
    elif name == "update_plan":
        explanation = payload.get("explanation", "")
        if explanation:
            parts.append(f'<div class="dim">{html.escape(explanation)}</div>')
        plan = payload.get("plan", [])
        if isinstance(plan, list):
            lines = []
            for step in plan:
                if isinstance(step, dict):
                    lines.append(f"[{step.get('status', '?')}] {step.get('step', '')}")
            if lines:
                parts.append(f"<pre>{html.escape(chr(10).join(lines))}</pre>")
    elif name in ("spawn_agent", "send_input", "wait", "resume_agent", "close_agent", "web_search"):
        value_str = json.dumps(payload, indent=2, default=str)
        if len(value_str) > 1000:
            value_str = value_str[:1000] + f"\n...({len(value_str)} chars)"
        parts.append(f"<pre>{html.escape(value_str)}</pre>")
    else:
        for key, value in payload.items():
            parts.append(
                f'<span class="dim">{html.escape(key)}={html.escape(str(value)[:200])}</span>'
            )
    return "\n".join(parts)


def extract_result_text(block: dict[str, Any]) -> str:
    content = block.get("content", "")
    if isinstance(content, list):
        return "\n".join(
            part.get("text", "")
            for part in content
            if isinstance(part, dict)
        )
    return str(content) if content else ""


def build_result_html(text: str, is_error: bool, args: argparse.Namespace) -> str | None:
    if args.no_tool_results or not text.strip():
        return None
    limit = len(text) if args.full_output else 3000
    trunc = text[:limit]
    if len(text) > limit:
        trunc += f"\n...({len(text)} chars)"
    err_cls = ' class="err"' if is_error else ""
    res_cls = " err-result" if is_error else ""
    label = "Error" if is_error else "Output"
    return (
        f'<details class="result{res_cls}"><summary>{label} ({len(text)} chars)</summary>'
        f"<pre{err_cls}>{html.escape(trunc)}</pre></details>"
    )


def iconize(rendered: str, icon: str) -> str:
    if not icon:
        return rendered
    if rendered.startswith("<p>"):
        return rendered.replace("<p>", f"<p>{icon}", 1)
    return icon + rendered


def wrap_error(rendered: str, is_error: bool) -> str:
    if not is_error:
        return rendered
    return f'<div class="error-text">{rendered}</div>'


def estimate_message_size(content: Any) -> int:
    if isinstance(content, str):
        return len(content)
    if not isinstance(content, list):
        return 0
    size = 0
    for block in content:
        if not isinstance(block, dict):
            continue
        size += len(block.get("text", ""))
        payload = block.get("input", "")
        if isinstance(payload, str):
            size += len(payload)
        elif payload:
            size += len(json.dumps(payload, default=str))
    return size


def parse_transcript(path: str, args: argparse.Namespace) -> dict[str, Any]:
    redactor = Redactor(args)
    turns: list[dict[str, Any]] = []
    current_turn: dict[str, Any] | None = None
    pending_tools: dict[str, dict[str, Any]] = {}
    malformed_lines = 0
    session_meta: dict[str, Any] = {}

    def flush_turn() -> None:
        nonlocal current_turn
        if current_turn and (current_turn.get("user_text") or current_turn.get("items")):
            turns.append(current_turn)
        current_turn = None

    def ensure_turn(ts: str) -> dict[str, Any]:
        nonlocal current_turn
        if current_turn is None:
            current_turn = {
                "type": "turn",
                "user_text": "",
                "user_ts": ts,
                "user_is_error": False,
                "items": [],
                "duration_ms": 0,
                "has_errors": False,
                "output_tokens": 0,
                "input_tokens": 0,
                "turn_id": "",
            }
        return current_turn

    with open(path, encoding="utf-8", errors="replace") as handle:
        for lineno, line in enumerate(handle, 1):
            if lineno % 50000 == 0:
                print(f"  ...line {lineno}")
            try:
                record = json_loads(line)
            except Exception as exc:
                malformed_lines += 1
                if args.strict:
                    raise ValueError(f"{path}:{lineno}: invalid JSON: {exc}") from exc
                continue

            rtype = record.get("type")
            ts = record.get("timestamp", "")

            if rtype == "session_meta":
                payload = record.get("payload", {})
                if isinstance(payload, dict):
                    session_meta = payload
                continue

            if rtype == "compacted":
                flush_turn()
                turns.append({"type": "compaction", "ts": ts, "tokens": ""})
                continue

            payload = record.get("payload")
            if not isinstance(payload, dict):
                continue

            payload_type = payload.get("type")

            if payload_type == "context_compacted":
                flush_turn()
                turns.append({"type": "compaction", "ts": ts, "tokens": ""})
                continue

            if payload_type == "user_message":
                flush_turn()
                text = redactor.redact_text(strip_system_tags(payload.get("message", "")))
                current_turn = {
                    "type": "turn",
                    "user_text": text,
                    "user_ts": ts,
                    "user_is_error": bool(ERROR_TEXT_RE.search(text)),
                    "items": [],
                    "duration_ms": 0,
                    "has_errors": False,
                    "output_tokens": 0,
                    "input_tokens": 0,
                    "turn_id": "",
                }
                continue

            if payload_type == "task_started":
                turn = ensure_turn(ts)
                turn["turn_id"] = payload.get("turn_id", "")
                continue

            if payload_type == "turn_aborted":
                turn = ensure_turn(ts)
                turn["truncated"] = True
                turn["has_errors"] = True
                continue

            if payload_type == "task_complete":
                turn = ensure_turn(ts)
                turn["turn_id"] = turn.get("turn_id") or payload.get("turn_id", "")
                continue

            if payload_type == "token_count":
                turn = ensure_turn(ts)
                info = payload.get("info", {})
                usage = {}
                if isinstance(info, dict):
                    usage = info.get("last_token_usage") or info.get("total_token_usage") or {}
                if isinstance(usage, dict):
                    turn["input_tokens"] = max(
                        turn.get("input_tokens", 0),
                        int(usage.get("input_tokens", 0)) + int(usage.get("cached_input_tokens", 0)),
                    )
                    turn["output_tokens"] = max(
                        turn.get("output_tokens", 0),
                        int(usage.get("output_tokens", 0)) + int(usage.get("reasoning_output_tokens", 0)),
                    )
                continue

            if payload_type == "agent_message":
                turn = ensure_turn(ts)
                text = redactor.redact_text(strip_system_tags(payload.get("message", "").strip()))
                if text:
                    turn["items"].append(
                        {
                            "kind": "reply",
                            "ts": ts,
                            "text": text,
                            "phase": payload.get("phase", ""),
                            "is_error": bool(ERROR_TEXT_RE.search(text)),
                        }
                    )
                    if ERROR_TEXT_RE.search(text):
                        turn["has_errors"] = True
                continue

            if payload_type == "reasoning":
                text = redactor.redact_text(codex_reasoning_text(payload))
                if text:
                    ensure_turn(ts)["items"].append({"kind": "thinking", "ts": ts, "text": text})
                continue

            if payload_type in ("function_call", "custom_tool_call"):
                turn = ensure_turn(ts)
                raw_input = payload.get("arguments", "") if payload_type == "function_call" else payload.get("input", "")
                parsed_input = parse_tool_input(raw_input)
                tool_call = {
                    "kind": "tool_call",
                    "ts": ts,
                    "block": {
                        "name": payload.get("name", "?"),
                        "input": redactor.redact_obj(parsed_input),
                        "raw_input": redactor.redact_text(str(raw_input)),
                        "call_id": payload.get("call_id", ""),
                    },
                    "result_text": None,
                    "result_is_error": False,
                    "diff_adds": 0,
                    "diff_dels": 0,
                    "inner_tools": [],
                }
                turn["items"].append(tool_call)
                call_id = payload.get("call_id", "")
                if call_id:
                    pending_tools[call_id] = tool_call
                continue

            if payload_type == "web_search_call":
                ensure_turn(ts)["items"].append(
                    {
                        "kind": "tool_call",
                        "ts": ts,
                        "block": {
                            "name": "web_search",
                            "input": redactor.redact_obj(payload),
                            "raw_input": "",
                            "call_id": "",
                        },
                        "result_text": None,
                        "result_is_error": False,
                        "diff_adds": 0,
                        "diff_dels": 0,
                        "inner_tools": [],
                    }
                )
                continue

            if payload_type in ("function_call_output", "custom_tool_call_output"):
                text, is_error = parse_tool_output_text(payload.get("output"))
                text = redactor.redact_text(text)
                if not text.strip():
                    continue
                call_id = payload.get("call_id", "")
                tool_call = pending_tools.get(call_id)
                if tool_call is not None:
                    tool_call["result_text"] = text
                    tool_call["result_is_error"] = is_error
                    if is_error:
                        ensure_turn(ts)["has_errors"] = True
                elif not is_boilerplate_result(text, args):
                    turn = ensure_turn(ts)
                    turn["items"].append(
                        {
                            "kind": "tool_output",
                            "ts": ts,
                            "text": text,
                            "is_error": is_error,
                        }
                    )
                    if is_error:
                        turn["has_errors"] = True
                continue

    flush_turn()

    total_input = sum(turn.get("input_tokens", 0) for turn in turns if turn["type"] == "turn")
    total_output = sum(turn.get("output_tokens", 0) for turn in turns if turn["type"] == "turn")
    total_cache_create = 0
    total_cache_read = 0
    cost_total = None

    return {
        "turns": turns,
        "turn_count": sum(1 for turn in turns if turn["type"] == "turn"),
        "compaction_count": sum(1 for turn in turns if turn["type"] == "compaction"),
        "total_tool_calls": sum(
            1
            for turn in turns
            if turn["type"] == "turn"
            for item in turn["items"]
            if item["kind"] == "tool_call"
        ),
        "total_input": total_input,
        "total_output": total_output,
        "total_cache_create": total_cache_create,
        "total_cache_read": total_cache_read,
        "cost_total": cost_total,
        "malformed_lines": malformed_lines,
        "redactor": redactor,
        "session_meta": session_meta,
    }


def render_tool_row(tool_call: dict[str, Any], args: argparse.Namespace) -> str:
    summary, icon = tool_summary(tool_call["block"])
    body = tool_detail(tool_call["block"], args)
    result_html = None
    if tool_call.get("result_text") and not is_boilerplate_result(tool_call["result_text"], args):
        result_html = build_result_html(
            tool_call["result_text"],
            tool_call.get("result_is_error", False),
            args,
        )

    inner = body
    if result_html:
        inner += "\n" + result_html
    inner_tools = tool_call.get("inner_tools", [])
    if inner_tools:
        inner += f'\n<div class="agent-inner"><div class="dim">{len(inner_tools)} inner tool calls</div>'
        for inner_block in inner_tools:
            inner_summary, inner_icon = tool_summary(inner_block)
            inner += (
                '<div class="agent-tool-row">'
                f'<span class="badge {inner_icon}">{inner_icon}</span>'
                f'<span class="tsum">{html.escape(inner_summary)}</span>'
                "</div>"
            )
        inner += "</div>"
    count_suffix = f' <span class="dim">({len(inner_tools)} inner)</span>' if inner_tools else ""
    return (
        '<details class="trow">'
        f'<summary><span class="badge {icon}">{icon}</span>'
        f'<span class="tsum">{html.escape(summary)}{count_suffix}</span></summary>'
        f'<div class="tbody">{inner}</div>'
        "</details>"
    )


def gap_str(ms: float) -> str:
    hours = ms / 3_600_000
    if hours >= 24:
        return f"{hours / 24:.0f}d"
    if hours >= 1:
        return f"{hours:.0f}h"
    return f"{ms / 60000:.0f}m"


def auto_title(path: str, turns: list[dict[str, Any]], turn_count: int, session_meta: dict[str, Any] | None = None) -> str:
    project = ""
    cwd = ""
    if isinstance(session_meta, dict):
        cwd = session_meta.get("cwd", "")
    if cwd:
        project = os.path.basename(cwd.rstrip(os.sep))
    if not project:
        project = os.path.basename(os.path.dirname(os.path.abspath(path)))
    if project in ("", "home", os.path.basename(os.path.expanduser("~"))):
        project = ""
    first_user = ""
    for turn in turns:
        if turn["type"] == "turn" and turn.get("user_text", "").strip():
            first_user = turn["user_text"].strip().split("\n")[0][:80]
            break
    pieces = [piece for piece in (project, first_user) if piece]
    return ": ".join(pieces) if pieces else f"Codex Transcript - {turn_count} turns"


